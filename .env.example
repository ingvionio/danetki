# Скопируй этот файл в .env и заполни значения:
#   cp .env.example .env

# ----------------------------------------------------------------
#  Ollama — локальная LLM для AI Worker
#
#  Раскомментируй ту строку, которая соответствует твоей машине.
#  Каждый разработчик ставит свою модель в локальном .env —
#  это не влияет на других, .env в репозиторий не коммитится.
#
#  Чтобы модель скачалась, после первого запуска docker-compose
#  выполни:  docker exec danetka-ollama ollama pull $OLLAMA_MODEL
# ----------------------------------------------------------------

OLLAMA_MODEL=qwen2.5:3b       # CPU-only, ~5-15 сек на запрос, скромное качество
# OLLAMA_MODEL=qwen2.5:7b     # GPU 6-8 ГБ VRAM, ~2-5 сек, хорошее качество
# OLLAMA_MODEL=qwen2.5:14b    # GPU 12+ ГБ VRAM, ~3-7 сек, отличное качество
