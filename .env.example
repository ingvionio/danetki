# Скопируй этот файл в .env и заполни значения:
#   cp .env.example .env

# ----------------------------------------------------------------
#  Выбор LLM-провайдера для AI Worker
#  Значения: ollama | gigachat | openai
# ----------------------------------------------------------------

LLM_PROVIDER=ollama

# ----------------------------------------------------------------
#  Ollama — локальная LLM
#
#  Раскомментируй ту строку, которая соответствует твоей машине.
#  Каждый разработчик ставит свою модель в локальном .env —
#  это не влияет на других, .env в репозиторий не коммитится.
#
#  Чтобы модель скачалась, после первого запуска docker-compose
#  выполни:  docker exec danetka-ollama ollama pull $OLLAMA_MODEL
# ----------------------------------------------------------------

OLLAMA_MODEL=qwen2.5:3b       # CPU-only, ~5-15 сек на запрос, скромное качество
# OLLAMA_MODEL=qwen2.5:7b     # GPU 6-8 ГБ VRAM, ~2-5 сек, хорошее качество
# OLLAMA_MODEL=qwen2.5:14b    # GPU 12+ ГБ VRAM, ~3-7 сек, отличное качество

# ----------------------------------------------------------------
#  GigaChat (Sber)
#  Регистрация: https://developers.sber.ru/portal/products/gigachat-api
#  В кабинете создаёшь проект и получаешь "Authorization key" —
#  одну длинную base64-строку (внутри уже зашиты Client ID и Secret).
#  Free-tier scope для физлица: GIGACHAT_API_PERS (~1М токенов/мес).
# ----------------------------------------------------------------

# GIGACHAT_AUTH_KEY=
# GIGACHAT_MODEL=GigaChat
# GIGACHAT_SCOPE=GIGACHAT_API_PERS

# Сбер использует SSL-сертификат Минцифры РФ, которого нет
# в стандартном trust-store. Для dev обходим проверку:
# GIGACHAT_TRUST_ALL_CERTS=true

# ----------------------------------------------------------------
#  OpenAI-совместимый провайдер (DeepSeek / OpenRouter / Mistral / Groq / ...)
#  Используется когда LLM_PROVIDER=openai.
#
#  По умолчанию настроено под DeepSeek (доступен из РФ без VPN, цены копеечные).
#  Регистрация: https://platform.deepseek.com — нужен депозит ~$2.
#  Модели:
#    deepseek-chat      — DeepSeek-V3, основная (≈GPT-4o уровень)
#    deepseek-reasoner  — DeepSeek-R1, для сложных рассуждений (дороже, дольше)
#
#  Для других провайдеров:
#    OpenRouter:  OPENAI_BASE_URL=https://openrouter.ai/api/v1
#                 OPENAI_MODEL=anthropic/claude-3.5-sonnet (например)
#    Mistral:     OPENAI_BASE_URL=https://api.mistral.ai/v1
#                 OPENAI_MODEL=mistral-large-latest
#    Groq:        OPENAI_BASE_URL=https://api.groq.com/openai/v1
#                 OPENAI_MODEL=llama-3.3-70b-versatile
# ----------------------------------------------------------------

# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_API_KEY=
# OPENAI_MODEL=deepseek-chat
